{
  "name": "tommotv",
  "version": "1.3.1",
  "description": "Custom Apple TV media client — Jellyfin, media discovery, smart home, AI-powered UI",
  "main": "expo-router/entry",
  "author": "Chris Hasson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hassoncs/tomotv.git"
  },
  "bugs": {
    "url": "https://github.com/hassoncs/tomotv/issues"
  },
  "homepage": "https://github.com/hassoncs/tomotv",
  "keywords": [
    "jellyfin",
    "tvos",
    "apple-tv",
    "react-native",
    "video-player",
    "streaming",
    "expo",
    "transcoding",
    "mkv",
    "media-server",
    "media-center",
    "home-theater"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "npx expo lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
    "prebuild": "expo prebuild --clean",
    "lib": "npm uninstall expo-tvos-search && npm cache clean --force && npm install expo-tvos-search@github:keiver/expo-tvos-search#tint-fix && rm -rf .expo .metro-cache && yes | EXPO_TV=1 npx expo prebuild --clean && npx expo start --clear",
    "clear": "rm -rf .expo .metro-cache node_modules package-lock.json && npm i && yes | EXPO_TV=1 npx expo prebuild --clean && npx expo start --clear"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.0",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "expo": "54.0.23",
    "expo-blur": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-modules-core": "~3.0.25",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-tvos-dictation": "file:modules/expo-tvos-dictation",
    "expo-tvos-search": "~2.0.0",
    "react": "19.1.0",
    "react-native": "npm:react-native-tvos@0.81.4-0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-video": "^6.19.0",
    "react-native-worklets": "^0.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-tvos/config-tv": "^0.1.4",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "~29.7.0",
    "jest-expo": "^54.0.13",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "overrides": {
    "react-dom": "19.1.0",
    "expo-modules-core": "~3.0.25"
  },
  "private": true
}
