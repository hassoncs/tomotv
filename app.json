{
  "expo": {
    "name": "RadMedia",
    "slug": "radmedia",
    "description": "Custom Apple TV media client. Jellyfin browser, media discovery, smart home control.",
    "version": "1.3.1",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "radmedia",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1C1C1E",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hasson.radmedia",
      "buildNumber": "1",
      "version": "1.3.1",
      "appleTeamId": "24T4GAP365",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "RadBot needs to access your local network to connect to your Jellyfin media server and stream videos to your Apple TV.",
        "NSBonjourServices": [
          "_jellyfin._tcp"
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/input-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F47B20",
          "dark": {
            "backgroundColor": "#1C1C1E"
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "tvosDeploymentTarget": "15.1"
        }
      ],
      "expo-secure-store",
      "./plugins/withMultiAudioResourceLoader",
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "com.hasson.radmedia"
    }
  }
}