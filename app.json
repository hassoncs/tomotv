{
  "expo": {
    "name": "tomotv",
    "slug": "tomotv",
    "description": "Stream any video from your Jellyfin server. Automatic transcoding handles incompatible formats so you can just hit play and watch. Made for Apple TV.",
    "version": "1.1.1",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "tomotv",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.keiver.tomotv",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSLocalNetworkUsageDescription": "TomoTV needs to access your local network to connect to your Jellyfin media server and stream videos to your Apple TV.",
        "NSBonjourServices": ["_jellyfin._tcp"]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#B33939",
          "dark": {
            "backgroundColor": "#B33939"
          }
        }
      ],
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "tvosDeploymentTarget": "15.1",
          "appleTVImages": {
            "icon": "./assets/images/tvos-flattened/icon-1280x768.png",
            "iconSmall": "./assets/images/tvos-flattened/icon-400x240.png",
            "iconSmall2x": "./assets/images/tvos-flattened/icon-800x480.png",
            "topShelf": "./assets/images/tvos-flattened/topshelf-1920x720.png",
            "topShelf2x": "./assets/images/tvos-flattened/topshelf-3840x1440.png",
            "topShelfWide": "./assets/images/tvos-flattened/topshelf-wide-2320x720.png",
            "topShelfWide2x": "./assets/images/tvos-flattened/topshelf-wide-4640x1440.png"
          }
        }
      ],
      "expo-secure-store",
      "expo-video",
      "./plugins/withMultiAudioResourceLoader"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "dev.keiver.tomotv"
    }
  }
}
