# Jellyfin Development Configuration
# Copy this file to .env.local and fill in your local Jellyfin server details
# These are ONLY used for local development and are NOT included in production builds
# Users will configure their own servers via the Settings screen
# This during development will set the default server, API key, and user ID for easier testing

# Example: http://192.168.1.100:8096 or http://localhost:8096
EXPO_PUBLIC_DEV_JELLYFIN_SERVER=

# Get from Jellyfin Dashboard → API Keys → Create new key
EXPO_PUBLIC_DEV_JELLYFIN_API_KEY=

# Get from Jellyfin user profile settings
EXPO_PUBLIC_DEV_JELLYFIN_USER_ID=
