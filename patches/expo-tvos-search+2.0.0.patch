 /// Provides ONLY the native `.searchable` search bar (with keyboard + mic button)
 /// over a transparent background. React Native children fill the space below
 /// via UIKit layout in ExpoTvosSearchView.
+///
+/// The `.searchable` modifier is kept on the root content (Color.clear) so the
+/// two-way text binding stays properly wired. A hidden Button overlay with
+/// `prefersDefaultFocus` is the focusable UIKit bridge that lets the tvOS focus
+/// engine enter this NavigationView from the tab bar — without breaking the binding.
 struct InputModeContentView: View {
     @ObservedObject var viewModel: SearchViewModel
+    @Namespace private var focusNamespace
 
     var body: some View {
         NavigationView {
             Color.clear
+                .ignoresSafeArea()
+                // Invisible Button overlay: provides a focusable target so the tvOS
+                // focus engine can enter this NavigationView from the UIKit tab bar.
+                // `prefersDefaultFocus` makes it the default focus element.
+                // Kept separate from .searchable so the binding is not disturbed.
+                .overlay(
+                    Button(action: {}) { Color.clear }
+                        .buttonStyle(.plain)
+                        .frame(maxWidth: .infinity, maxHeight: .infinity)
+                        .prefersDefaultFocus(in: focusNamespace)
+                )
                 .searchable(text: $viewModel.searchText, prompt: viewModel.placeholder)
                 .onChange(of: viewModel.searchText) { newValue in
                     viewModel.onSearch?(newValue)
                 }
         }
+        .focusScope(focusNamespace)
+        .background(Color.clear)
         .tint(viewModel.accentColor)
         .modifier(TopInsetModifier(topInset: viewModel.topInset))
     }
